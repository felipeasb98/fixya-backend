generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id               String      @id @default(uuid())
  nombre           String
  email            String      @unique
  telefono         String
  passwordHash     String
  avatarUrl        String?
  rut              String?     @unique
  emailVerificado  Boolean     @default(false)
  telefonoVerif    Boolean     @default(false)
  fcmToken         String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  solicitudes  Solicitud[]
  ratingsDados Rating[]    @relation("RatingCliente")

  @@map("usuarios")
}

model Tecnico {
  id                  String    @id @default(uuid())
  nombre              String
  email               String    @unique
  telefono            String
  passwordHash        String
  avatarUrl           String?
  rut                 String    @unique
  descripcion         String?
  banco               String?
  tipoCuenta          String?
  numeroCuenta        String?
  emailBanco          String?
  secCertificado      Boolean   @default(false)
  secDocUrl           String?
  secVencimiento      DateTime?
  secVerificado       Boolean   @default(false)
  activo              Boolean   @default(false)
  disponible          Boolean   @default(false)
  comisionPct         Float     @default(18.0)
  plan                String    @default("normal")
  ratingPromedio      Float     @default(0)
  totalRatings        Int       @default(0)
  trabajosCompletados Int       @default(0)
  latitud             Float?
  longitud            Float?
  ubicacionAt         DateTime?
  fcmToken            String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  rubros        TecnicoRubro[]
  postulaciones Postulacion[]
  trabajos      Solicitud[]    @relation("TecnicoAsignado")
  ratings       Rating[]       @relation("RatingAlTecnico")
  pagos         Pago[]

  @@map("tecnicos")
}

model Rubro {
  id     String  @id @default(uuid())
  nombre String  @unique
  emoji  String
  activo Boolean @default(true)

  tecnicos    TecnicoRubro[]
  solicitudes Solicitud[]

  @@map("rubros")
}

model TecnicoRubro {
  tecnicoId String
  rubroId   String
  tecnico   Tecnico @relation(fields: [tecnicoId], references: [id], onDelete: Cascade)
  rubro     Rubro   @relation(fields: [rubroId], references: [id], onDelete: Cascade)

  @@id([tecnicoId, rubroId])
  @@map("tecnico_rubros")
}

model Solicitud {
  id                    String          @id @default(uuid())
  codigo                String          @unique
  usuarioId             String
  usuario               Usuario         @relation(fields: [usuarioId], references: [id])
  rubroId               String
  rubro                 Rubro           @relation(fields: [rubroId], references: [id])
  tecnicoId             String?
  tecnico               Tecnico?        @relation("TecnicoAsignado", fields: [tecnicoId], references: [id])
  trabajo               String
  descripcion           String?
  urgencia              String          @default("normal")
  moBase                Float
  matEstimado           Float           @default(0)
  totalEstimado         Float
  totalFinal            Float?
  latitud               Float?
  longitud              Float?
  direccion             String?
  comuna                String?
  fotosProblema         String[]
  fotosTrabajo          String[]
  fotosCierre           String[]
  agendado              Boolean         @default(false)
  fechaAgendada         DateTime?
  bloqueHorario         String?
  estado                EstadoSolicitud @default(PENDIENTE)
  tecnicoAceptoAt       DateTime?
  tecnicoEnCaminoAt     DateTime?
  trabajoInicioAt       DateTime?
  trabajoFinAt          DateTime?
  clienteConfirmoAt     DateTime?
  canceladoAt           DateTime?
  motivoCancelacion     String?
  materialesConfirmados Boolean         @default(false)
  reporteFaltante       String?
  moModificada          Float?
  motivoModTarifa       String?
  modTarifaEstado       String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  postulaciones Postulacion[]
  pago          Pago?
  rating        Rating?

  @@map("solicitudes")
}

enum EstadoSolicitud {
  PENDIENTE
  CON_POSTULANTES
  CONFIRMADO
  EN_CAMINO
  EN_TRABAJO
  ESPERANDO_CONF
  COMPLETADO
  CANCELADO
  DISPUTADO
}

model Postulacion {
  id          String    @id @default(uuid())
  solicitudId String
  solicitud   Solicitud @relation(fields: [solicitudId], references: [id], onDelete: Cascade)
  tecnicoId   String
  tecnico     Tecnico   @relation(fields: [tecnicoId], references: [id])
  mensaje     String?
  tiempoEta   Int?
  estado      String    @default("pendiente")
  createdAt   DateTime  @default(now())

  @@unique([solicitudId, tecnicoId])
  @@map("postulaciones")
}

model Pago {
  id            String     @id @default(uuid())
  solicitudId   String     @unique
  solicitud     Solicitud  @relation(fields: [solicitudId], references: [id])
  tecnicoId     String
  tecnico       Tecnico    @relation(fields: [tecnicoId], references: [id])
  monto         Float
  comisionPct   Float
  comisionMonto Float
  montoTecnico  Float
  metodo        String
  estado        EstadoPago @default(PENDIENTE)
  proveedorId   String?
  proveedorData Json?
  escrowAt      DateTime?
  liberadoAt    DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@map("pagos")
}

enum EstadoPago {
  PENDIENTE
  EN_ESCROW
  LIBERADO
  REEMBOLSADO
  DISPUTADO
}

model Rating {
  id                String    @id @default(uuid())
  solicitudId       String    @unique
  solicitud         Solicitud @relation(fields: [solicitudId], references: [id])
  estrellasTecnico  Int?
  comentarioTecnico String?
  clienteId         String
  cliente           Usuario   @relation("RatingCliente", fields: [clienteId], references: [id])
  estrellasCliente  Int?
  comentarioCliente String?
  tecnicoId         String
  tecnicoRef        Tecnico   @relation("RatingAlTecnico", fields: [tecnicoId], references: [id])
  createdAt         DateTime  @default(now())

  @@map("ratings")
}

model Notificacion {
  id          String   @id @default(uuid())
  destinoId   String
  destinoTipo String
  titulo      String
  cuerpo      String
  tipo        String
  leida       Boolean  @default(false)
  data        Json?
  createdAt   DateTime @default(now())

  @@map("notificaciones")
}
